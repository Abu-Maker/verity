{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "node"
    ],
    "paths": {
      "@verity/shared/*": [
        "./packages/shared/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "apps"
  ],
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}