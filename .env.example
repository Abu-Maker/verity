# ============================================================
# Verity — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# Chain RPCs — get from alchemy.com
ETH_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=

# Scanner config (set per Railway worker — override per service)
CHAIN_ID=1
POLL_INTERVAL=5000
BATCH_SIZE=5

# Circle — from console.circle.com
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_ENTITY_CIPHERTEXT=
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
CIRCLE_USDC_TOKEN_ID=

# Agent
VERITY_PAYMENT_ADDRESS=
VERITY_API_URL=http://localhost:3000
AGENT_API_KEY=vrt_pro_test_key_32chars_xxxxxxxxx
AGENT_INTERVAL=300000

# API
API_PORT=3000
API_SECRET=

# Dashboard (Vercel)
VITE_API_URL=https://your-api-url.railway.app